{% if cart.item_count > 0 %}
  <script>window.location.replace('/checkout');</script>
  <div style="padding:48px 20px;text-align:center;">
    <p style="font-size:16px;color:var(--verde-oscuro);">Redirigiendo al checkout...</p>
  </div>
{% else %}
  <div style="padding:64px 20px;text-align:center;max-width:500px;margin:0 auto;">
    <h1 style="font-family:var(--font-display);font-size:32px;color:var(--verde-oscuro);margin-bottom:16px;">Tu Carrito</h1>
    <p style="font-size:48px;margin-bottom:16px;">🛒</p>
    <p style="font-size:16px;color:var(--texto-medio);margin-bottom:24px;">Tu carrito está vacío</p>
    <a href="/products/k9clean-disolvente-de-pelo-de-mascota" class="btn btn-primary" style="display:inline-block;padding:14px 32px;background:var(--dorado);color:var(--verde-oscuro);border-radius:40px;font-weight:700;text-decoration:none;">Ver producto</a>
  </div>
{% endif %}
