{% if cart.item_count > 0 %}
  <!-- Si hay items, redirigir directo al checkout -->
  <script>window.location.replace('/checkout');</script>
  <div class="container" style="padding: 48px 20px; text-align: center;">
    <p style="font-size:18px; color:var(--verde-oscuro);">Redirigiendo al checkout...</p>
  </div>
{% else %}
  <div class="container" style="padding: 48px 20px; max-width: 800px; margin: 0 auto; text-align: center;">
    <h1 style="font-family: var(--font-display); font-size: 32px; color: var(--verde-oscuro); margin-bottom: 24px;">Tu Carrito</h1>
    <p style="font-size:48px; margin-bottom:16px;">🛒</p>
    <p style="font-size:18px; color:var(--texto-medio); margin-bottom:24px;">Tu carrito está vacío</p>
    <a href="/products/k9clean-disolvente-de-pelo-de-mascota" class="btn btn-primary">Ver producto</a>
  </div>
{% endif %}
