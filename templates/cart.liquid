<div class="container" style="padding: 48px 20px; max-width: 800px; margin: 0 auto;">
  <h1 style="font-family: var(--font-display); font-size: 32px; color: var(--verde-oscuro); text-align: center; margin-bottom: 32px;">Tu Carrito</h1>

  {% if cart.item_count > 0 %}
    <form action="/cart" method="post">
      {% for item in cart.items %}
        <div style="display:flex; gap:16px; align-items:center; padding:20px 0; border-bottom:1px solid rgba(201,169,97,0.25);">
          <div style="flex:1;">
            <p style="font-weight:700; color:var(--verde-oscuro); font-size:16px;">{{ item.product.title }}</p>
            <p style="font-size:13px; color:var(--texto-medio);">{{ item.variant.title }}</p>
            <p style="font-size:14px; color:var(--texto-medio); margin-top:4px;">Cantidad: {{ item.quantity }}</p>
          </div>
          <p style="font-size:18px; font-weight:700; color:var(--verde-oscuro);">{{ item.line_price | money }}</p>
        </div>
      {% endfor %}

      <div style="text-align:right; padding:24px 0; border-top:2px solid var(--verde-oscuro);">
        <p style="font-size:14px; color:var(--texto-medio);">Subtotal</p>
        <p style="font-size:24px; font-weight:700; color:var(--verde-oscuro);">{{ cart.total_price | money }}</p>
      </div>

      <div style="text-align:center; margin-top:16px;">
        <button type="submit" name="checkout" class="btn btn-primary" style="width:100%; max-width:400px; padding:18px; font-size:18px; cursor:pointer;">
          Finalizar compra
        </button>
        <p style="font-size:12px; color:var(--texto-claro); margin-top:12px;">Serás redirigido al checkout seguro de Mercado Pago</p>
      </div>
    </form>
  {% else %}
    <div style="text-align:center; padding:48px 0;">
      <p style="font-size:48px; margin-bottom:16px;">🛒</p>
      <p style="font-size:18px; color:var(--texto-medio); margin-bottom:24px;">Tu carrito está vacío</p>
      <a href="/pages/producto" class="btn btn-primary">Ver producto</a>
    </div>
  {% endif %}
</div>
