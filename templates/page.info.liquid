{% layout 'theme.info' %}
<style>
/* ============================================================
   PAGE.INFO — Presell Listicle K9Clean Argentina
   Self-contained styles. Fonts loaded by theme.liquid.
   ============================================================ */

/* ---------- BASE ---------- */
.info-page {
  font-family: 'DM Sans', sans-serif;
  color: #2d2d2d;
  line-height: 1.7;
  font-size: 17px;
  background: #ffffff;
  overflow-x: hidden;
}
.info-page *,
.info-page *::before,
.info-page *::after {
  box-sizing: border-box;
}
.info-page img {
  display: block;
  max-width: 100%;
  height: auto;
}

/* ---------- UTILITIES ---------- */
.info-wrap {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 20px;
}
.info-page h2,
.info-page h3 {
  font-family: 'Playfair Display', serif;
  color: #17433c;
  line-height: 1.25;
}
.info-page h2 {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  margin-bottom: 0.6em;
}
.info-page h3 {
  font-size: clamp(1.35rem, 3vw, 1.85rem);
  margin-bottom: 0.5em;
}
.info-page p {
  margin: 0 0 1.15em;
}

/* ---------- CTA BUTTONS ---------- */
.info-cta {
  display: inline-block;
  background: linear-gradient(135deg, #c9a961 0%, #f4d99a 100%);
  color: #17433c;
  font-family: 'DM Sans', sans-serif;
  font-weight: 700;
  font-size: 16px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 16px 38px;
  border-radius: 40px;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  text-align: center;
}
.info-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(201, 169, 97, 0.45);
}

/* ---------- STAR RATING ---------- */
.info-stars {
  display: inline-flex;
  gap: 2px;
  color: #f4b740;
  font-size: 18px;
  line-height: 1;
}
.info-social-line {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 14px;
  font-size: 14px;
  color: rgba(255,255,255,0.85);
  flex-wrap: wrap;
}
.info-social-line--dark {
  color: #555;
}

/* ============================================================
   SECTION 1 — HERO
   ============================================================ */
.info-hero {
  background: linear-gradient(160deg, #17433c 0%, #1a5248 100%);
  color: #fff;
  padding: 50px 0 56px;
}
.info-hero__inner {
  display: flex;
  flex-direction: column;
  gap: 32px;
  align-items: center;
}
.info-hero__img {
  width: 100%;
  max-width: 420px;
  border-radius: 16px;
}
.info-hero__text {
  text-align: center;
}
.info-hero__text h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.65rem, 5vw, 2.65rem);
  line-height: 1.2;
  margin: 0 0 20px;
  color: #fff;
}
.info-hero__sub {
  font-size: 16px;
  line-height: 1.7;
  opacity: 0.92;
  margin-bottom: 28px;
}
.info-hero__sub strong {
  color: #f4d99a;
}

@media (min-width: 768px) {
  .info-hero {
    padding: 70px 0 76px;
  }
  .info-hero__inner {
    flex-direction: row;
    gap: 48px;
  }
  .info-hero__img {
    width: 45%;
    flex-shrink: 0;
  }
  .info-hero__text {
    text-align: left;
    flex: 1;
  }
}

/* ============================================================
   REASON SECTIONS (alternating layout)
   ============================================================ */
.info-reason {
  padding: 56px 0;
  border-bottom: 1px solid #eaeaea;
}
.info-reason:last-of-type {
  border-bottom: none;
}
.info-reason__inner {
  display: flex;
  flex-direction: column;
  gap: 32px;
  align-items: center;
}
.info-reason__text {
  flex: 1;
}
.info-reason__text p {
  color: #444;
}
.info-reason__img-wrap {
  width: 100%;
  max-width: 480px;
}
.info-reason__img-wrap img {
  border-radius: 12px;
  width: 100%;
}

@media (min-width: 768px) {
  .info-reason {
    padding: 72px 0;
  }
  .info-reason__inner {
    flex-direction: row;
    gap: 52px;
  }
  .info-reason__img-wrap {
    width: 46%;
    flex-shrink: 0;
  }
  .info-reason--reversed .info-reason__inner {
    flex-direction: row-reverse;
  }
}

/* ---------- CHECKLIST (Reason 3) ---------- */
.info-checklist {
  list-style: none;
  padding: 0;
  margin: 20px 0 28px;
}
.info-checklist li {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  margin-bottom: 16px;
  line-height: 1.6;
  color: #444;
}
.info-check-icon {
  flex-shrink: 0;
  width: 26px;
  height: 26px;
  background: #17433c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2px;
}
.info-check-icon svg {
  width: 14px;
  height: 14px;
  stroke: #fff;
  fill: none;
  stroke-width: 3;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* ============================================================
   SOCIAL PROOF BANNER
   ============================================================ */
.info-social-banner {
  background: #f8f3fa;
  padding: 56px 0;
  text-align: center;
}
.info-social-banner h2 {
  margin-bottom: 8px;
}
.info-social-banner__sub {
  font-size: 15px;
  color: #666;
  margin-bottom: 24px;
}
.info-social-banner blockquote {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: clamp(1.1rem, 2.8vw, 1.45rem);
  color: #333;
  margin: 0 auto 10px;
  max-width: 640px;
  line-height: 1.5;
  padding: 0;
  border: none;
}
.info-social-banner cite {
  font-style: normal;
  font-size: 14px;
  color: #888;
  display: block;
  margin-bottom: 28px;
}
.info-social-line--center {
  justify-content: center;
  color: #555;
}

/* ============================================================
   PRODUCT CTA SECTION
   ============================================================ */
.info-product-cta {
  padding: 64px 0;
  text-align: center;
  background: #fafaf7;
}
.info-product-cta__img {
  width: 240px;
  margin: 0 auto 24px;
  border-radius: 14px;
}
.info-product-cta h2 {
  font-size: clamp(1.4rem, 3.2vw, 2rem);
  max-width: 700px;
  margin: 0 auto 16px;
}
.info-product-cta__desc {
  max-width: 600px;
  margin: 0 auto 28px;
  color: #555;
  font-size: 16px;
}
.info-product-cta .info-cta {
  font-size: 18px;
  padding: 18px 44px;
}
.info-trust-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 16px;
  font-size: 13px;
  color: #777;
}
.info-trust-line svg {
  width: 16px;
  height: 16px;
  stroke: #17433c;
  fill: none;
  stroke-width: 2;
  flex-shrink: 0;
}

/* ============================================================
   REVIEWS SECTION
   ============================================================ */
.info-reviews {
  padding: 60px 0;
  background: #fff;
}
.info-reviews h2 {
  text-align: center;
  margin-bottom: 36px;
}
.info-reviews__track {
  display: flex;
  gap: 24px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 12px;
}
.info-reviews__track::-webkit-scrollbar {
  height: 6px;
}
.info-reviews__track::-webkit-scrollbar-thumb {
  background: #ccc;
  border-radius: 3px;
}
.info-review-card {
  flex: 0 0 85%;
  max-width: 360px;
  scroll-snap-align: start;
  background: #fafafa;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid #eee;
}
.info-review-card__img {
  width: 100%;
  aspect-ratio: 1;
  object-fit: contain;
  background: #f8f8f6;
  padding: 8px;
}
.info-review-card__body {
  padding: 20px 22px 24px;
}
.info-review-card__stars {
  color: #f4b740;
  font-size: 16px;
  margin-bottom: 8px;
}
.info-review-card__title {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  color: #17433c;
  margin: 0 0 8px;
  font-weight: 700;
  line-height: 1.3;
}
.info-review-card__text {
  font-size: 14.5px;
  color: #555;
  line-height: 1.65;
  margin: 0 0 12px;
}
.info-review-card__author {
  font-size: 13px;
  color: #888;
  font-weight: 600;
}

@media (min-width: 768px) {
  .info-reviews__track {
    overflow: visible;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .info-review-card {
    flex: none;
    max-width: none;
  }
}

/* ============================================================
   FAQ SECTION
   ============================================================ */
.info-faq {
  padding: 60px 0 72px;
  background: #fff;
}
.info-faq h2 {
  text-align: center;
  margin-bottom: 36px;
}
.info-faq__list {
  max-width: 800px;
  margin: 0 auto;
}
.info-faq-item {
  border-bottom: 1px solid #e2e2e2;
}
.info-faq-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  background: none;
  border: none;
  padding: 20px 0;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  font-size: 16px;
  font-weight: 600;
  color: #1d1d1d;
  text-align: left;
  gap: 16px;
  line-height: 1.4;
}
.info-faq-trigger:hover {
  color: #17433c;
}
.info-faq-chevron {
  flex-shrink: 0;
  width: 22px;
  height: 22px;
  transition: transform 0.3s ease;
  stroke: #666;
}
.info-faq-trigger[aria-expanded="true"] .info-faq-chevron {
  transform: rotate(180deg);
}
.info-faq-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease, padding 0.35s ease;
  padding: 0 0;
}
.info-faq-panel[aria-hidden="false"] {
  padding: 0 0 20px;
}
.info-faq-panel p {
  font-size: 15px;
  color: #555;
  line-height: 1.7;
  margin: 0;
}

/* ============================================================
   FOOTER DISCLAIMER
   ============================================================ */
.info-footer-disclaimer {
  background: #17433c;
  color: rgba(255,255,255,0.88);
  padding: 36px 0;
  text-align: center;
  font-size: 13px;
  line-height: 1.7;
}
.info-footer-disclaimer strong {
  display: block;
  font-size: 15px;
  color: #fff;
  margin-bottom: 10px;
}
.info-footer-disclaimer p {
  max-width: 800px;
  margin: 0 auto;
  color: rgba(255,255,255,0.72);
}
</style>

