{% layout 'theme.info' %}

<style>
  .advp {
    font-family: 'DM Sans', -apple-system, sans-serif;
    color: #1a1a1a;
    background: #fff;
    line-height: 1.8;
    font-size: 17px;
  }
  .advp *, .advp *::before, .advp *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* HOOK / HERO */
  .advp-hook {
    background: #17433c;
    padding: 48px 20px 0;
    text-align: center;
  }
  .advp-hook-badge {
    display: block;
    color: #c9a961;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 16px;
  }
  .advp-headline {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 600;
    font-size: clamp(27px, 5.2vw, 36px);
    color: #fff;
    line-height: 1.28;
    letter-spacing: -0.2px;
    max-width: 660px;
    margin: 0 auto 18px;
  }
  .advp-headline strong { font-weight: 700; }
  .advp-hook-sub {
    color: rgba(255,255,255,0.7);
    font-size: 16px;
    max-width: 540px;
    margin: 0 auto 32px;
  }
  .advp-hook-img {
    max-width: 680px;
    margin: 0 auto;
    border-top: 1px solid rgba(255,255,255,0.12);
  }
  .advp-hook-img img { width: 100%; display: block; }
  .advp-hook-img-caption {
    color: rgba(255,255,255,0.5);
    font-size: 12.5px;
    font-style: italic;
    padding: 10px 16px 0;
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }
  .advp-hook-trust {
    color: rgba(255,255,255,0.55);
    font-size: 12.5px;
    padding: 18px 16px 0;
    text-align: center;
  }
  .advp-hook-spacer { height: 32px; }

  /* STOCK */
  .advp-stock {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    width: max-content;
    max-width: 100%;
    background: #fdf2ee;
    border: 1px solid #e8c4b6;
    border-radius: 30px;
    padding: 9px 20px;
    margin: 28px auto;
  }
  .advp-stock-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #b3492f;
    flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(179,73,47,0.5);
    animation: advp-pulse 1.8s infinite;
  }
  .advp-stock p {
    font-size: 12px;
    line-height: 1;
    font-weight: 600;
    color: #8a3a26;
    margin: 0;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    white-space: nowrap;
  }
  @keyframes advp-pulse {
    0% { box-shadow: 0 0 0 0 rgba(179,73,47,0.45); }
    70% { box-shadow: 0 0 0 6px rgba(179,73,47,0); }
    100% { box-shadow: 0 0 0 0 rgba(179,73,47,0); }
  }

  /* WRAP */
  .advp-wrap { max-width: 660px; margin: 0 auto; padding: 44px 20px; }

  .advp-wrap p { margin-bottom: 1.3em; color: #2b2b2b; }
  .advp-wrap h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 600;
    font-size: 24px;
    color: #17433c;
    margin: 40px 0 16px;
    line-height: 1.35;
    letter-spacing: -0.1px;
  }

  /* LISTA DE PROBLEMAS */
  .advp-problem-list { margin: 22px 0 30px; }
  .advp-problem-item {
    display: flex;
    gap: 18px;
    padding: 18px 0;
    border-top: 1px solid #e8e5dd;
  }
  .advp-problem-item:last-child { border-bottom: 1px solid #e8e5dd; }
  .advp-problem-icon {
    width: 30px;
    flex-shrink: 0;
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 600;
    font-size: 16px;
    color: #c9a961;
  }
  .advp-problem-text h4 { font-size: 15.5px; font-weight: 700; color: #17433c; margin-bottom: 5px; }
  .advp-problem-text p { font-size: 14.5px; color: #555; margin: 0; }

  /* CALLOUT PRECIO */
  .advp-cost-callout {
    background: #fdf2ee;
    border: 1px solid #e8c4b6;
    border-left: 4px solid #b3492f;
    border-radius: 6px;
    padding: 26px 24px;
    text-align: center;
    margin: 32px 0;
  }
  .advp-cost-callout .eyebrow {
    display: block;
    font-size: 11.5px;
    font-weight: 700;
    color: #b3492f;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }
  .advp-cost-callout .label { font-size: 13.5px; color: #6b4338; }
  .advp-cost-callout .amount {
    font-family: 'DM Sans', sans-serif;
    font-size: 42px;
    font-weight: 700;
    color: #b3492f;
    display: block;
    margin: 8px 0;
    letter-spacing: -0.5px;
  }
  .advp-cost-callout .note { color: #8a6358; font-size: 12.5px; margin: 0; }

  /* IMAGEN INLINE */
  .advp-img { margin: 30px -20px; }
  .advp-img img { width: 100%; display: block; }
  @media (min-width: 768px) {
    .advp-img { margin: 34px 0; }
    .advp-img img { border-radius: 4px; }
  }

  /* QUOTE TÉCNICO */
  .advp-quote-tech {
    position: relative;
    padding: 6px 0 6px 24px;
    margin: 30px 0;
    border-left: 2px solid #c9a961;
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    color: #17433c;
  }

  /* SOLUCIÓN BOX */
  .advp-solution-box {
    background: #faf9f6;
    border: 1px solid #e8e5dd;
    border-radius: 6px;
    padding: 30px 24px;
    margin: 34px 0;
    text-align: center;
  }
  .advp-solution-box img { width: 130px; margin: 0 auto 18px; display: block; }
  .advp-solution-box h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 600;
    font-size: 20px;
    color: #17433c;
    margin-bottom: 10px;
  }
  .advp-solution-box p { font-size: 14px; color: #555; max-width: 420px; margin: 0 auto; }

  /* CTA */
  .advp-cta-wrap { text-align: center; margin: 34px 0; }
  .advp-cta-btn {
    display: inline-block;
    background: #17433c;
    color: #fff;
    padding: 15px 40px;
    border-radius: 4px;
    font-family: 'DM Sans', sans-serif;
    font-size: 15.5px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .advp-cta-btn:hover { background: #0f2e29; }
  .advp-cta-trust { margin-top: 14px; font-size: 12.5px; color: #999; letter-spacing: 0.1px; }

  /* TESTIMONIOS */
  .advp-testi-section { background: #faf9f6; padding: 44px 0; margin: 36px 0; border-top: 1px solid #e8e5dd; border-bottom: 1px solid #e8e5dd; }
  .advp-testi-section h2 { text-align: center; }
  .advp-testi-grid { display: grid; gap: 16px; margin-top: 28px; }
  .advp-testi-card {
    background: #fff;
    border: 1px solid #e8e5dd;
    border-radius: 6px;
    padding: 22px;
  }
  .advp-testi-stars { color: #c9a961; font-size: 14px; margin-bottom: 10px; letter-spacing: 1px; }
  .advp-testi-card p { font-size: 14.5px; color: #444; margin-bottom: 12px; font-style: italic; }
  .advp-testi-card cite {
    font-style: normal;
    font-size: 12.5px;
    font-weight: 600;
    color: #17433c;
  }

  /* FOOTER LEGAL */
  .advp-footer {
    max-width: 660px;
    margin: 0 auto;
    padding: 24px 20px 44px;
    font-size: 11px;
    color: #aaa;
    border-top: 1px solid #eee;
    line-height: 1.6;
  }
</style>

