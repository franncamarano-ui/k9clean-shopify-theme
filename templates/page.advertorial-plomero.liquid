{% layout 'theme.info' %}

<style>
  .advp {
    font-family: 'DM Sans', -apple-system, sans-serif;
    color: #1a1a1a;
    background: #fff;
    line-height: 1.8;
    font-size: 17px;
  }
  .advp *, .advp *::before, .advp *::after { box-sizing: border-box; margin: 0; padding: 0; }

  /* HEADER TÉCNICO */
  .advp-header {
    background: #1f2d2b;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border-bottom: 3px solid #c9a961;
  }
  .advp-header-icon {
    width: 30px; height: 30px;
    background: #c9a961;
    border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
  }
  .advp-header-icon svg { width: 18px; height: 18px; color: #17433c; }
  .advp-header-text { color: #fff; font-weight: 700; font-size: 16px; letter-spacing: -0.3px; }
  .advp-header-text span { color: #c9a961; }

  /* HOOK / HERO */
  .advp-hook {
    background: #17433c;
    padding: 40px 20px 0;
    text-align: center;
  }
  .advp-hook-badge {
    display: inline-block;
    background: rgba(255,255,255,0.1);
    color: #c9a961;
    border: 1px solid rgba(201,169,97,0.4);
    padding: 5px 14px;
    border-radius: 40px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 18px;
  }
  .advp-headline {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(26px, 6vw, 38px);
    color: #fff;
    line-height: 1.2;
    max-width: 700px;
    margin: 0 auto 16px;
    font-weight: 700;
  }
  .advp-headline em { color: #c9a961; font-style: italic; }
  .advp-hook-sub {
    color: rgba(255,255,255,0.75);
    font-size: 16px;
    max-width: 560px;
    margin: 0 auto 28px;
  }
  .advp-hook-img {
    max-width: 720px;
    margin: 0 auto;
  }
  .advp-hook-img img { width: 100%; display: block; }
  .advp-hook-img-caption {
    background: #fff3cd;
    color: #856404;
    font-size: 12px;
    font-weight: 700;
    padding: 8px 16px;
    text-align: center;
  }

  /* WRAP */
  .advp-wrap { max-width: 680px; margin: 0 auto; padding: 40px 20px; }

  .advp-wrap p { margin-bottom: 1.3em; color: #333; }
  .advp-wrap h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 26px;
    color: #17433c;
    margin: 36px 0 16px;
    line-height: 1.3;
  }
  .advp-wrap h2 em { color: #c9a961; font-style: italic; }

  /* LISTA DE PROBLEMAS */
  .advp-problem-list { margin: 20px 0 28px; }
  .advp-problem-item {
    display: flex;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid #eee;
  }
  .advp-problem-icon {
    width: 32px; height: 32px;
    background: #fdecea;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    font-size: 16px;
  }
  .advp-problem-text h4 { font-size: 15px; color: #17433c; margin-bottom: 4px; }
  .advp-problem-text p { font-size: 14px; color: #555; margin: 0; }

  /* CALLOUT PRECIO */
  .advp-cost-callout {
    background: #17433c;
    color: #fff;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin: 28px 0;
  }
  .advp-cost-callout .amount {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 36px;
    color: #c9a961;
    font-weight: 700;
    display: block;
    margin: 6px 0;
  }
  .advp-cost-callout p { color: rgba(255,255,255,0.8); font-size: 13px; margin: 0; }

  /* IMAGEN INLINE */
  .advp-img { margin: 28px -20px; }
  .advp-img img { width: 100%; display: block; }
  @media (min-width: 768px) {
    .advp-img { margin: 32px 0; }
    .advp-img img { border-radius: 10px; }
  }

  /* QUOTE TÉCNICO */
  .advp-quote-tech {
    background: #f4f1eb;
    border-left: 4px solid #17433c;
    border-radius: 0 8px 8px 0;
    padding: 20px 24px;
    margin: 24px 0;
    font-style: italic;
    color: #333;
  }

  /* SOLUCIÓN BOX */
  .advp-solution-box {
    background: #fff;
    border: 2px solid #c9a961;
    border-radius: 14px;
    padding: 28px 24px;
    margin: 32px 0;
    text-align: center;
  }
  .advp-solution-box img { width: 140px; margin: 0 auto 16px; display: block; border-radius: 10px; }
  .advp-solution-box h3 {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 22px;
    color: #17433c;
    margin-bottom: 10px;
  }
  .advp-solution-box p { font-size: 14px; color: #555; }

  /* CTA */
  .advp-cta-wrap { text-align: center; margin: 32px 0; }
  .advp-cta-btn {
    display: inline-block;
    background: linear-gradient(135deg, #c9a961, #b8943f);
    color: #17433c;
    padding: 16px 44px;
    border-radius: 40px;
    font-size: 16px;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .advp-cta-btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(201,169,97,0.4); }
  .advp-cta-trust { margin-top: 12px; font-size: 12px; color: #999; }

  /* TESTIMONIOS */
  .advp-testi-section { background: #f4f1eb; padding: 40px 0; margin: 32px 0; }
  .advp-testi-section h2 { text-align: center; }
  .advp-testi-grid { display: grid; gap: 16px; margin-top: 24px; }
  .advp-testi-card {
    background: #fff;
    border-radius: 10px;
    padding: 20px;
  }
  .advp-testi-stars { color: #c9a961; font-size: 15px; margin-bottom: 8px; }
  .advp-testi-card p { font-size: 14px; color: #444; margin-bottom: 10px; }
  .advp-testi-card cite {
    font-style: normal;
    font-size: 12px;
    font-weight: 700;
    color: #17433c;
  }

  /* FOOTER LEGAL */
  .advp-footer {
    max-width: 680px;
    margin: 0 auto;
    padding: 20px 20px 40px;
    font-size: 11px;
    color: #aaa;
    border-top: 1px solid #eee;
    line-height: 1.6;
  }
</style>

