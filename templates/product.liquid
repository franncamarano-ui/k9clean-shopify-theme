<!-- PRODUCTO — K9 Clean Argentina -->
<style>
  /* Force product grid layout with !important to override theme defaults */
  .product-hero { overflow-x: hidden !important; }
  .product-hero .container {
    display: grid !important;
    grid-template-columns: 1fr !important;
    gap: 28px !important;
    align-items: start !important;
    max-width: 100% !important;
    padding: 0 16px !important;
    overflow: hidden !important;
  }
  .product-gallery, .product-info { max-width: 100% !important; overflow: hidden !important; }
  .product-gallery img { max-width: 100% !important; height: auto !important; }
  @media (min-width: 768px) {
    .product-hero .container {
      grid-template-columns: 1fr 1fr !important;
      gap: 40px !important;
    }
  }
  .product-gallery { order: 1 !important; }
  .product-info  { order: 2 !important; }

  /* Thumbnail rows */
  .product-gallery__thumbs {
    display: grid !important;
    gap: 6px !important;
    margin-top: 6px !important;
  }
  .product-gallery__thumbs--row1 { grid-template-columns: repeat(5, 1fr) !important; }
  .product-gallery__thumbs--row2 { grid-template-columns: repeat(4, 1fr) !important; }

  .product-gallery__thumb {
    cursor: pointer;
    border: 2px solid transparent;
    border-radius: 6px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .product-gallery__thumb.active,
  .product-gallery__thumb:hover {
    border-color: var(--dorado) !important;
  }
  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 4px;
  }

  /* Benefits grid */
  .benefits-grid {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    gap: 10px !important;
    margin: 16px 0 !important;
  }
  .benefit-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px;
    background: var(--crema-alt);
    border-radius: 8px;
  }
  .benefit-item__icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: var(--verde-oscuro);
  }
  .benefit-item__icon svg { width: 100%; height: 100%; }
  .benefit-item__text {
    font-size: 12px;
    font-weight: 600;
    color: var(--verde-oscuro);
    line-height: 1.3;
  }

  /* Offer section */
  .offer-section { margin: 20px 0 16px; }
  .offer-section__title {
    text-align: center;
    font-size: 13px;
    color: var(--texto-medio);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .offer-option {
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 12px;
    border: 2px solid var(--borde-sutil);
    border-radius: 10px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .offer-option:hover { border-color: var(--dorado); }
  .offer-option.selected {
    border-color: var(--verde-oscuro) !important;
    background: rgba(23,67,60,0.04);
  }
  .offer-option__badge {
    position: absolute;
    top: -10px;
    right: 12px;
    background: var(--verde-oscuro);
    color: var(--dorado);
    font-size: 10px;
    font-weight: 700;
    padding: 2px 10px;
    border-radius: 4px;
    text-transform: uppercase;
  }
  .offer-option__radio {
    width: 18px;
    height: 18px;
    border: 2px solid var(--borde-sutil);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
    transition: border-color 0.2s;
  }
  .offer-option.selected .offer-option__radio {
    border-color: var(--verde-oscuro);
  }
  .offer-option.selected .offer-option__radio::after {
    content: '';
    position: absolute;
    top: 3px; left: 3px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--verde-oscuro);
  }
  .offer-option__icon { font-size: 16px; flex-shrink: 0; }
  .offer-option__info { flex: 1; min-width: 0; }
  .offer-option__name { font-size: 14px; font-weight: 700; color: var(--verde-oscuro); margin: 0; }
  .offer-option__wash { font-size: 11px; font-weight: 500; color: var(--texto-claro); margin-left: 4px; }
  .offer-option__sub { font-size: 11px; color: var(--texto-medio); margin: 2px 0 0; }
  .offer-option__price { text-align: right; flex-shrink: 0; }
  .offer-option__current { font-size: 18px; font-weight: 800; color: var(--verde-oscuro); margin: 0; }
  .offer-option__original { font-size: 12px; color: var(--texto-claro); text-decoration: line-through; margin: 0; }

  /* CTA buttons */
  .product-cta { display: flex; flex-direction: column; gap: 10px; margin: 16px 0; }
  .product-cta .btn-buy {
    width: 100%;
    padding: 16px;
    font-size: 16px;
    cursor: pointer;
    background: linear-gradient(135deg, var(--dorado), #b8943f);
    color: var(--verde-oscuro);
    border: none;
    border-radius: 40px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .product-cta .btn-buy:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(201,169,97,0.4); }
  .product-cta .btn-cart {
    width: 100%;
    padding: 14px;
    font-size: 14px;
    cursor: pointer;
    background: transparent;
    color: var(--verde-oscuro);
    border: 2px solid var(--dorado);
    border-radius: 40px;
    font-weight: 600;
    transition: background 0.2s;
  }
  .product-cta .btn-cart:hover { background: rgba(201,169,97,0.08); }

  /* Trust & payments */
  .product-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    padding: 14px 0;
  }
  .product-trust__item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--verde-oscuro);
    font-weight: 600;
  }
  .product-trust__item svg { width: 16px; height: 16px; }
  .product-payments {
    display: flex;
    justify-content: center;
    gap: 12px;
    font-size: 12px;
    color: var(--texto-medio);
    padding-bottom: 14px;
  }

  /* Info tabs */
  .info-tabs { margin-top: 24px; border-top: 1px solid var(--borde-sutil); padding-top: 20px; }
  .info-tabs__nav {
    display: flex;
    border-bottom: 2px solid var(--borde-sutil);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .info-tabs__nav::-webkit-scrollbar { display: none; }
  .info-tab-btn {
    padding: 10px 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--texto-medio);
    background: none;
    white-space: nowrap;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .info-tab-btn.active {
    color: var(--verde-oscuro);
    border-bottom-color: var(--dorado);
  }
  .info-tab-panel { padding: 16px 0; display: none; }
  .info-tab-panel.active { display: block; }

  /* Formulado section */
  .formulado-grid { display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center; }
  @media (min-width: 768px) {
    .formulado-grid { grid-template-columns: 1fr 1fr !important; gap: 48px !important; }
  }
  .formulado__item { margin-bottom: 20px; }
  .formulado__item h3 { font-size: 16px; color: var(--dorado); margin-bottom: 6px; border-bottom: 1px solid rgba(201,169,97,0.3); padding-bottom: 4px; display: inline-block; }
  .formulado__item p { font-size: 14px; color: rgba(255,255,255,0.85); line-height: 1.6; }

  /* Resultados grid */
  .resultados-grid { display: grid; grid-template-columns: 1fr; gap: 32px; align-items: center; }
  @media (min-width: 768px) {
    .resultados-grid { grid-template-columns: 1fr 1fr !important; }
  }

  /* Reviews track */
  .reviews-track::-webkit-scrollbar { display: none; }
</style>

