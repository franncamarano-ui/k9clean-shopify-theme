<section class="product-hero">
  <div class="container">

    <!-- GALERÍA (order 1) -->
    <div class="product-gallery fade-in">
      <div class="product-gallery__main">
        <img id="mainProductImg" src="{{ 'producto1.jpg' | asset_url }}" alt="K9 Clean Producto" style="width:100%;border-radius:16px;display:block;" fetchpriority="high" loading="eager">
      </div>
      <!-- Thumbnails row 1: 5 images -->
      <div class="product-gallery__thumbs product-gallery__thumbs--row1">
        <div class="product-gallery__thumb active" data-img="{{ 'producto1.jpg' | asset_url }}">
          <img src="{{ 'producto1.jpg' | asset_url }}" alt="Producto" loading="eager">
        </div>
        <div class="product-gallery__thumb" data-img="{{ 'producto8.jpg' | asset_url }}">
          <img src="{{ 'producto8.jpg' | asset_url }}" alt="Producto detalle" loading="lazy">
        </div>
        <div class="product-gallery__thumb" data-img="{{ 'competencia2.jpg' | asset_url }}">
          <img src="{{ 'competencia2.jpg' | asset_url }}" alt="Comparacion" loading="lazy">
        </div>
        <div class="product-gallery__thumb" data-img="{{ 'antesdespues3.jpg' | asset_url }}">
          <img src="{{ 'antesdespues3.jpg' | asset_url }}" alt="Antes y despues" loading="lazy">
        </div>
        <div class="product-gallery__thumb" data-img="{{ 'clientes4.jpg' | asset_url }}">
          <img src="{{ 'clientes4.jpg' | asset_url }}" alt="Clientes" loading="lazy">
        </div>
      </div>
      <!-- Thumbnails row 2: 4 images -->
      <div class="product-gallery__thumbs product-gallery__thumbs--row2">
        <div class="product-gallery__thumb" data-img="{{ 'beneficios5.jpg' | asset_url }}">
          <img src="{{ 'beneficios5.jpg' | asset_url }}" alt="Beneficios" loading="lazy">
        </div>
        <div class="product-gallery__thumb" data-img="{{ 'uso6.jpg' | asset_url }}">
          <img src="{{ 'uso6.jpg' | asset_url }}" alt="Como usar" loading="lazy">
        </div>
        <div class="product-gallery__thumb" data-img="{{ 'efecto7.jpg' | asset_url }}">
          <img src="{{ 'efecto7.jpg' | asset_url }}" alt="Efecto" loading="lazy">
        </div>
        <div class="product-gallery__thumb" data-img="{{ 'nuevolook9.jpg' | asset_url }}">
          <img src="{{ 'nuevolook9.jpg' | asset_url }}" alt="Nuevo packaging" loading="lazy">
        </div>
      </div>
    </div>

    <!-- PRODUCT INFO (order 2) -->
    <div class="product-info fade-in">
      <h1 class="product-info__title">K9Clean Disolvente de Pelo de Mascota</h1>

      <p class="product-info__meta">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--verde-oscuro)"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        100g / ~8 ciclos de lavado
      </p>

      <p class="product-info__desc">Polvo enzimatico a base de plantas que rompe la queratina para liberar el pelo de mascota incrustado en telas y lavarropas. Resultados progresivos, sin esfuerzo extra.</p>

      <!-- NOTA: Rating y cantidad de reseñas son ilustrativos. Reemplazar con datos reales cuando estén disponibles. -->
      <div class="product-info__rating">
        <span class="product-info__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <strong style="font-size:13px;color:var(--verde-oscuro);">4.8</strong>
        <span style="font-size:13px;color:var(--texto-medio);">· 127 reseñas</span>
      </div>

      <!-- Bullets de beneficios clave — visibles sin click -->
      <ul style="list-style:none;margin:0 0 16px;padding:0;">
        <li style="display:flex;align-items:flex-start;gap:8px;padding:5px 0;font-size:13px;color:var(--texto-medio);">
          <span style="color:var(--verde-oscuro);font-weight:700;flex-shrink:0;">&#10003;</span>
          Disuelve hasta el <strong style="color:var(--verde-oscuro);">96.7%</strong> del pelo acumulado en telas y lavarropas
        </li>
        <li style="display:flex;align-items:flex-start;gap:8px;padding:5px 0;font-size:13px;color:var(--texto-medio);">
          <span style="color:var(--verde-oscuro);font-weight:700;flex-shrink:0;">&#10003;</span>
          Limpia el tambor, filtro y componentes internos en cada lavado
        </li>
        <li style="display:flex;align-items:flex-start;gap:8px;padding:5px 0;font-size:13px;color:var(--texto-medio);">
          <span style="color:var(--verde-oscuro);font-weight:700;flex-shrink:0;">&#10003;</span>
          Previene reparaciones costosas del lavarropas a largo plazo
        </li>
        <li style="display:flex;align-items:flex-start;gap:8px;padding:5px 0;font-size:13px;color:var(--texto-medio);">
          <span style="color:var(--verde-oscuro);font-weight:700;flex-shrink:0;">&#10003;</span>
          Sin esfuerzo extra — se agrega al lavado normal, sin pasos nuevos
        </li>
      </ul>

      <!-- POCO STOCK -->
      <div style="background:#fff3cd;border:1px solid #e6c34d;border-radius:8px;padding:10px 16px;margin-bottom:16px;text-align:center;">
        <p style="font-size:13px;font-weight:700;color:#856404;margin:0;">🔥 ¡Poco stock disponible!</p>
      </div>

      <!-- KACHING BUNDLES + FORMULARIO NATIVO -->
      <div class="shop-product-section" data-product-id="{{ product.id }}">
        {% form 'product', product, id: 'product-form', class: 'product-form' %}
          <select name="id" id="productSelect" style="display:none;">
            {% for variant in product.variants %}
              <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                {{ variant.title }} — {{ variant.price | money }}
              </option>
            {% endfor %}
          </select>
          <!-- Botón directo al checkout -->
          <button type="submit" name="checkout" class="btn-buy" id="buyNowBtnProduct" style="width:100%;padding:16px;font-size:16px;cursor:pointer;background:linear-gradient(135deg,#c9a961,#b8943f);color:#17433c;border:none;border-radius:40px;font-weight:700;text-transform:uppercase;">Comprar ahora</button>
          <!-- Mini trust strip pegado al botón -->
          <div style="display:flex;justify-content:center;gap:12px;margin-top:10px;flex-wrap:wrap;">
            <span style="font-size:11px;color:var(--texto-medio);display:flex;align-items:center;gap:3px;">&#10003; Garantia 30 dias</span>
            <span style="font-size:11px;color:var(--texto-medio);">|</span>
            <span style="font-size:11px;color:var(--texto-medio);display:flex;align-items:center;gap:3px;">&#128666; Envio 3-7 dias habiles</span>
            <span style="font-size:11px;color:var(--texto-medio);">|</span>
            <span style="font-size:11px;color:var(--texto-medio);display:flex;align-items:center;gap:3px;">&#128274; Pago seguro</span>
          </div>
        {% endform %}
      </div>

      <!-- TRUST BADGES (visibles sin abrir nada) -->
      <div class="product-trust">
        <span class="product-trust__item">
          <svg viewBox="0 0 24 24" fill="var(--dorado)" stroke="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10" fill="none" stroke="var(--verde-oscuro)" stroke-width="2" stroke-linecap="round"/></svg>
          Garantia 30 dias
        </span>
        <span class="product-trust__item">&#128666; Envio 3-7 dias habiles</span>
        <span class="product-trust__item">
          <svg viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Pago seguro
        </span>
        <span class="product-trust__item">&#9851;&#65039; Apto pozo septico</span>
      </div>

      <!-- PAYMENT METHODS -->
      <div class="product-payments">
        <span>&#128179; Visa</span>
        <span>&#128181; Mercado Pago</span>
        <span>&#127974; Rapipago</span>
      </div>

      <!-- INFO TABS -->
      <div class="info-tabs">
        <div class="info-tabs__nav">
          <button class="info-tab-btn active" data-infotab="aprobado">Aprobado por dueños</button>
          <button class="info-tab-btn" data-infotab="ingredientes">Ingredientes clave</button>
          <button class="info-tab-btn" data-infotab="instrucciones">Instrucciones</button>
          <button class="info-tab-btn" data-infotab="beneficios">Beneficios</button>
        </div>

        <div class="info-tab-panel active" id="infotab-aprobado">
          <blockquote style="font-family:var(--font-display);font-size:14px;font-style:italic;color:var(--verde-oscuro);line-height:1.5;padding:16px;background:var(--crema-alt);border-radius:8px;border-left:3px solid var(--dorado);margin-bottom:12px;">
            "Tengo dos pastores alemanes y el lavarropas estaba hecho pelota de tanto pelo acumulado. Con un solo lavado con K9Clean, el lavarropas empezó a andar más tranquilo y ya no vivo con miedo de que se me rompa. Es lo primero que realmente funciona."
          </blockquote>
          <div style="display:flex;align-items:center;gap:10px;">
            <div style="width:32px;height:32px;border-radius:50%;background:var(--verde-oscuro);color:var(--dorado);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;">CH</div>
            <div>
              <strong style="font-size:13px;color:var(--verde-oscuro);">Carolina H.</strong><br>
              <span style="font-size:11px;color:var(--texto-claro);">Mama de perros full time, 2 hijos y 2 pastores.</span>
            </div>
          </div>
        </div>

        <div class="info-tab-panel" id="infotab-ingredientes">
