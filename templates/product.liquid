<!-- SCRIPTS                                                        -->
<!-- ============================================================ -->
<script>
(function(){
  /* ------------------------------------------ */
  /* THUMBNAIL GALLERY                           */
  /* ------------------------------------------ */
  var mainImg = document.getElementById('mainProductImg');
  var thumbs = document.querySelectorAll('.product-gallery__thumb');

  thumbs.forEach(function(thumb){
    thumb.addEventListener('click', function(){
      thumbs.forEach(function(t){ t.classList.remove('active'); });
      thumb.classList.add('active');
      if (mainImg && thumb.dataset.img) {
        mainImg.src = thumb.dataset.img;
      }
    });
  });

  /* ------------------------------------------ */
  /* INFO TABS                                   */
  /* ------------------------------------------ */
  var tabBtns = document.querySelectorAll('.info-tab-btn');
  tabBtns.forEach(function(btn){
    btn.addEventListener('click', function(){
      tabBtns.forEach(function(b){ b.classList.remove('active'); });
      btn.classList.add('active');
      document.querySelectorAll('.info-tab-panel').forEach(function(p){ p.classList.remove('active'); p.style.display = 'none'; });
      var target = document.getElementById('infotab-' + btn.dataset.infotab);
      if (target) { target.classList.add('active'); target.style.display = 'block'; }
    });
  });

  /* ------------------------------------------ */
  /* PACK SELECTION & VARIANT TRACKING           */
  /* ------------------------------------------ */
  /* Default to the "selected" pack (2 units), falling back to first available variant */
  var selectedVariant = null;
  var defaultSelected = document.querySelector('.offer-option.selected');
  if (defaultSelected && defaultSelected.dataset.variant) {
    selectedVariant = defaultSelected.dataset.variant;
  } else {
    selectedVariant = '{{ product.selected_or_first_available_variant.id }}';
  }

  document.querySelectorAll('.offer-option').forEach(function(opt){
    opt.addEventListener('click', function(){
      document.querySelectorAll('.offer-option').forEach(function(o){ o.classList.remove('selected'); });
      opt.classList.add('selected');
      if (opt.dataset.variant) {
        selectedVariant = opt.dataset.variant;
      }
    });
  });

  /* ------------------------------------------ */
  /* CART DRAWER UPDATE FUNCTION                 */
  /* ------------------------------------------ */
  function updateDrawer(cart) {
    var drawer = document.getElementById('cartDrawer');
    var body = document.getElementById('cartDrawerBody');
    var overlay = document.getElementById('cartOverlay');
    if (!drawer || !body) return;

    /* -- Remove any existing dynamic footer to prevent duplication -- */
    var existingFooters = drawer.querySelectorAll('.cart-drawer-footer');
    existingFooters.forEach(function(f){ f.remove(); });

    if (cart.item_count === 0) {
      body.innerHTML = '<div style="text-align:center;padding:48px 0;">' +
        '<p style="font-size:36px;margin-bottom:12px;">&#128722;</p>' +
        '<p style="font-size:15px;color:#4a4a4a;">Tu carrito esta vacio</p>' +
        '</div>';
    } else {
      /* Build items HTML */
      var html = '';
      cart.items.forEach(function(item) {
        var imgHtml = '';
        if (item.image) {
          imgHtml = '<img src="' + item.image + '" style="width:60px;height:60px;border-radius:8px;object-fit:cover;flex-shrink:0;">';
        } else {
          imgHtml = '<img src="{{ 'producto1.png' | asset_url }}" style="width:60px;height:60px;border-radius:8px;object-fit:cover;flex-shrink:0;">';
        }

        html += '<div style="display:flex;gap:12px;padding:14px 0;border-bottom:1px solid #f0f0f0;align-items:center;">';
        html += imgHtml;
        html += '<div style="flex:1;min-width:0;">';
        html += '<p style="font-size:14px;font-weight:600;color:#17433c;margin:0 0 2px;">' + item.product_title + '</p>';
        if (item.variant_title && item.variant_title !== 'Default Title') {
          html += '<p style="font-size:12px;color:#7a7a7a;margin:0 0 2px;">' + item.variant_title + '</p>';
        }
        html += '<p style="font-size:12px;color:#4a4a4a;margin:0;">Cant: ' + item.quantity + '</p>';
        html += '</div>';
        html += '<div style="text-align:right;flex-shrink:0;">';
        html += '<p style="font-size:15px;font-weight:700;color:#17433c;margin:0 0 4px;">$' + (item.line_price / 100).toLocaleString('es-AR') + '</p>';
        html += '<button onclick="removeCartItem(\'' + item.key + '\')" style="font-size:11px;color:#cc0000;text-decoration:underline;background:none;border:none;cursor:pointer;padding:0;">Eliminar</button>';
        html += '</div>';
        html += '</div>';
      });
      body.innerHTML = html;

      /* Build ONE footer with subtotal + checkout */
      var footer = document.createElement('div');
      footer.className = 'cart-drawer-footer';
      footer.style.cssText = 'padding:16px 20px;border-top:2px solid #17433c;background:#fafaf7;';
      footer.innerHTML =
        '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">' +
          '<span style="font-size:14px;color:#4a4a4a;">Subtotal</span>' +
          '<span style="font-size:20px;font-weight:700;color:#17433c;">$' + (cart.total_price / 100).toLocaleString('es-AR') + '</span>' +
        '</div>' +
        '<form action="/cart" method="post">' +
          '<button type="submit" name="checkout" style="width:100%;padding:14px;font-size:15px;cursor:pointer;background:linear-gradient(135deg,#c9a961,#b8943f);color:#17433c;border:none;border-radius:40px;font-weight:700;text-transform:uppercase;">Finalizar compra</button>' +
        '</form>' +
        '<a href="/products/k9clean-disolvente-de-pelo-de-mascota" style="display:block;text-align:center;margin-top:10px;font-size:13px;color:#c9a961;font-weight:600;">&#8592; Seguir comprando</a>';
      drawer.appendChild(footer);
    }

    /* Update cart count badge */
    var countEl = document.getElementById('cartCount');
    var toggleBtn = document.getElementById('cartToggle');
    if (cart.item_count > 0) {
      if (countEl) {
        countEl.textContent = cart.item_count;
      } else if (toggleBtn) {
        var badge = document.createElement('span');
        badge.id = 'cartCount';
        badge.style.cssText = 'position:absolute;top:-6px;right:-8px;background:#c9a961;color:#17433c;font-size:10px;font-weight:800;width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;';
        badge.textContent = cart.item_count;
        toggleBtn.appendChild(badge);
      }
    } else if (countEl) {
      countEl.remove();
    }

    /* Open the drawer */
    drawer.style.right = '0';
    if (overlay) overlay.style.display = 'block';
  }

  /* ------------------------------------------ */
  /* REMOVE ITEM FROM CART (used by drawer)      */
  /* ------------------------------------------ */
  window.removeCartItem = function(itemKey) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: itemKey, quantity: 0 })
    })
    .then(function(r){ return r.json(); })
    .then(function(cart){ updateDrawer(cart); });
  };

  /* ------------------------------------------ */
  /* ADD TO CART (shared by both buttons)        */
  /* ------------------------------------------ */
  function addToCart(goToCheckout) {
    var variantId = parseInt(selectedVariant);
    if (!variantId) return;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(function(r){ return r.json(); })
    .then(function(){
      if (goToCheckout) {
        /* Buy Now: go straight to checkout */
        window.location.href = '/checkout';
      } else {
        /* Add to Cart: fetch full cart and update drawer */
        fetch('/cart.js')
          .then(function(r){ return r.json(); })
          .then(function(cart){ updateDrawer(cart); });
      }
    })
    .catch(function(err){
      console.error('Error adding to cart:', err);
    });
  }

  /* ------------------------------------------ */
  /* BUTTON EVENT LISTENERS                      */
  /* ------------------------------------------ */
  var buyBtn = document.getElementById('buyNowBtn');
  var cartBtn = document.getElementById('addToCartBtn');
  if (buyBtn) buyBtn.addEventListener('click', function(){ addToCart(true); });
  if (cartBtn) cartBtn.addEventListener('click', function(){ addToCart(false); });

  /* ------------------------------------------ */
  /* BEFORE / AFTER SLIDER                       */
  /* ------------------------------------------ */
  var slider = document.getElementById('baSlider');
  var before = document.getElementById('baBefore');
  var handle = document.getElementById('baHandle');
  if (slider && before && handle) {
    var dragging = false;

    function moveSlider(x) {
      var rect = slider.getBoundingClientRect();
      var pos = Math.max(0, Math.min(x - rect.left, rect.width));
      var pct = (pos / rect.width) * 100;
      before.style.width = pct + '%';
      handle.style.left = pct + '%';
    }

    slider.addEventListener('mousedown', function(e){ dragging = true; moveSlider(e.clientX); });
    window.addEventListener('mousemove', function(e){ if (dragging) moveSlider(e.clientX); });
    window.addEventListener('mouseup', function(){ dragging = false; });

    slider.addEventListener('touchstart', function(e){ dragging = true; moveSlider(e.touches[0].clientX); }, {passive:true});
    window.addEventListener('touchmove', function(e){ if (dragging) moveSlider(e.touches[0].clientX); }, {passive:true});
    window.addEventListener('touchend', function(){ dragging = false; });
  }
})();
</script>
