  {{ 'k9clean.css' | asset_url | stylesheet_tag }}
  <script>
  /* Kaching cart fix — vaciar carrito completo al llegar a pagina de producto */
  (function(){
    var _XHR = window.XMLHttpRequest;

    function clearCart(done){
      var r = new _XHR();
      r.open('POST','/cart/clear.js',true);
      r.setRequestHeader('Content-Type','application/json');
      r.onload = r.onerror = function(){ if(done) done(); };
      r.send();
    }

    function maybeClear(){
      if(!document.querySelector('[data-product-id]')) return;
      clearCart(null);
    }

    // Carga normal
    document.addEventListener('DOMContentLoaded', maybeClear);
    // Restauracion desde bfcache (back button en mobile)
    window.addEventListener('pageshow', function(e){ if(e.persisted) maybeClear(); });

    // Interceptor XHR: limpiar carrito y redirigir al checkout tras add de Kaching
    window.XMLHttpRequest = function(){
      var xhr = new _XHR();
      var m='', u='';
      var oOpen=xhr.open.bind(xhr), oSend=xhr.send.bind(xhr);
      xhr.open = function(){ m=arguments[0]||''; u=arguments[1]||''; return oOpen.apply(null,arguments); };
      xhr.send = function(body){
        if(m.toUpperCase()==='POST' && u.indexOf('/cart/add')!==-1){
          if(document.querySelector('[data-product-id]')){
            var origOnLoad = xhr.onload;
            xhr.onload = function(e){
              if(origOnLoad) origOnLoad.call(xhr, e);
              window.location.href = '/checkout';
            };
            clearCart(function(){ oSend(body); }); return;
          }
        }
        return oSend(body);
      };
      return xhr;
    };

    // Fallback: interceptar fetch si Kaching usa fetch
    var _fetch = window.fetch ? window.fetch.bind(window) : null;
    if(_fetch){
      window.fetch = function(input,init){
        var u = typeof input==='string'?input:(input&&input.url?input.url:'');
        if(u.indexOf('/cart/add')!==-1 && document.querySelector('[data-product-id]')){
          return new Promise(function(res,rej){
            clearCart(function(){
              _fetch(input,init).then(function(r){ window.location.href='/checkout'; res(r); }).catch(rej);
            });
          });
        }
        return _fetch(input,init);
      };
    }
  })();
  </script>
  {{ content_for_header }}
</head>
